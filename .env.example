# ----------------------------------------------------------------------------
# Sara - Environment Variables
# Copy this file to ".env" and fill in real values.
# ----------------------------------------------------------------------------

# PostgreSQL connection string (Neon).
# Pooled connection for the app runtime.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
# Direct (non-pooled) connection used by Prisma migrations.
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Secret used to sign session JWTs. Generate with: openssl rand -base64 48
AUTH_SECRET="change-me-to-a-long-random-string"

# Public base URL of the deployment. Used for QR code destinations.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Initial super admin account created by `npm run db:seed`.
SUPER_ADMIN_EMAIL="admin@sara.app"
SUPER_ADMIN_PASSWORD="ChangeThisStrongPassword!1"

# Storage driver: "local" (filesystem, dev) or "blob" (Netlify Blobs, prod).
STORAGE_DRIVER="local"
